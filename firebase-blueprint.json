{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Base user document",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Folder": {
      "title": "Folder",
      "description": "File folder",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "File": {
      "title": "File",
      "description": "User uploaded file",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "size": { "type": "string" },
        "type": { "type": "string" },
        "storagePath": { "type": "string" },
        "downloadURL": { "type": "string" },
        "folderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "size", "type", "storagePath", "downloadURL", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "User note",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Workspace team member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "AccessGrant": {
      "title": "Access Grant",
      "description": "Cross-user workspace access",
      "type": "object",
      "properties": {
        "bossUid": { "type": "string" },
        "bossEmail": { "type": "string" },
        "subordinateEmail": { "type": "string" },
        "role": { "type": "string" },
        "grantedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bossUid", "bossEmail", "subordinateEmail", "role", "grantedAt"]
    },
    "DatabaseBackup": {
      "title": "Database Backup",
      "description": "Full SQLite state snapshot",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "data": { "type": "string" },
        "count": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "data", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/users/{userId}/folders/{folderId}": { "schema": "Folder", "description": "Folders" },
    "/users/{userId}/files/{fileId}": { "schema": "File", "description": "Files" },
    "/users/{userId}/notes/{noteId}": { "schema": "Note", "description": "Notes" },
    "/users/{userId}/teamMembers/{memberId}": { "schema": "TeamMember", "description": "Team members" },
    "/users/{userId}/backups/{backupId}": { "schema": "DatabaseBackup", "description": "Database backups" },
    "/access_grants/{grantId}": { "schema": "AccessGrant", "description": "Access grants" }
  }
}
